#
# Local-only environment variables for examples/*
# Copy to .env and fill in values. (Do NOT commit .env)
#

# DashScope OpenAI-compatible endpoint
LLM_BINDING_HOST="https://dashscope.aliyuncs.com/compatible-mode/v1"
LLM_BINDING_API_KEY="sk-8e3668afa0b3449784340f836f4d93f6"

# Models
LLM_MODEL="qwen2.5-omni-7b"
VISION_MODEL="qwen2.5-omni-7b"
EMBEDDING_BINDING="dashscope_mm"
EMBEDDING_MODEL="tongyi-embedding-vision-flash-2026-03-06"

# Optional dedicated key for DashScope SDK embedding path.
# If empty, webapp falls back to DASHSCOPE_API_KEY/LLM_BINDING_API_KEY/OPENAI_API_KEY in order.
DASHSCOPE_API_KEY=""

# Embedding dimension: set this to the actual dimension returned by your embedding model.
# If unsure, run the small probe snippet in the docs/assistant message, then fill it here.
EMBEDDING_DIM="768"

# Optional: default output directory for parsed documents
OUTPUT_DIR="./output"

# Optional: parser selection for document parsing
PARSER="mineru"
PARSE_METHOD="auto"

